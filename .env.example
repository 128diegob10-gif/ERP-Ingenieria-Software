# Puerto HTTP para Railway (Railway lo inyecta automáticamente)
PORT=3000

# Opcion 1 (recomendada): URL completa de conexion MySQL
# Puedes usar DATABASE_URL o MYSQL_URL
DATABASE_URL=mysql://user:password@host:3306/database

# Opcion 2: variables separadas
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=secret
# DB_NAME=erp_ventas

# Pool de conexiones (opcional)
DB_POOL_LIMIT=10
